# Copy this to .env.local and fill in values.
# NEVER commit .env.local.

# Alchemy free-tier Sepolia RPC: https://dashboard.alchemy.com/
ALCHEMY_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Private key for the deployer / institution wallet.
# Export from MetaMask: Account details → Show private key. Fund with Sepolia ETH first.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Etherscan API key for verifying the contract: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_KEY

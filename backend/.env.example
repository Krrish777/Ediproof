# Copy this to .env.local and fill in values.
PORT=8787
DB_PATH=./ediproof.db

# Pinata JWT — server-side only, NEVER expose to frontend
# Get one at: https://app.pinata.cloud/developers/api-keys
PINATA_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your dedicated Pinata gateway (optional, falls back to public gateway)
# e.g. https://emerald-casual-mule-123.mypinata.cloud
PINATA_GATEWAY=https://gateway.pinata.cloud
